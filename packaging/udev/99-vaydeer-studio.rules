# Vaydeer JP-1011: access only the command (0) and async event (2) HID interfaces.
# `KERNELS` matches the HID parent and DEVPATH selects the USB interface below it.
# Keeping those checks separate avoids mixing parent-match constraints from two
# sysfs levels, which udev intentionally treats as non-matching.
# TAG+=uaccess grants the active local-seat user access; plugdev remains a
# distribution fallback where uaccess ACLs are unavailable.
SUBSYSTEM=="hidraw", KERNELS=="0003:0483:5752.*", ENV{DEVPATH}=="*:1.0/*", MODE="0660", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="hidraw", KERNELS=="0003:0483:5752.*", ENV{DEVPATH}=="*:1.2/*", MODE="0660", GROUP="plugdev", TAG+="uaccess"

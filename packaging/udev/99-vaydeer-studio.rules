# Vaydeer JP-1011: access only the command (0) and async event (2) HID interfaces.
# TAG+=uaccess grants the active local seat user access; plugdev is a fallback on
# distributions that do not apply uaccess to hidraw nodes.
SUBSYSTEM=="hidraw", KERNELS=="*:1.0", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5752", MODE="0660", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="hidraw", KERNELS=="*:1.2", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="5752", MODE="0660", GROUP="plugdev", TAG+="uaccess"
